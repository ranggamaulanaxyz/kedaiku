{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server (React Router)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev -- --host",
            "cwd": "${workspaceFolder}",
            "sourceMaps": true
        },
        {
            "name": "Debug Client (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
        },
        {
            "name": "Attach to Cloudflare Worker",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "websocketAddress": "ws://127.0.0.1:9229/core:user:kedaiku",
            "cwd": "${workspaceFolder}",
            "resolveSourceMapLocations": null,
            "attachExistingChildren": false,
            "autoAttachChildProcesses": false,
            "sourceMaps": true
        }
    ],
    "compounds": [
        {
            "name": "Debug Full-Stack (Client & Server)",
            "configurations": [
                "Debug Server (React Router)",
                "Debug Client (Chrome)",
                "Attach to Cloudflare Worker"
            ]
        }
    ]
}