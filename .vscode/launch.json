{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server (React Router)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev -- --host",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Client (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Attach to Cloudflare Worker",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "websocketAddress": "ws://localhost:9229/my-react-router-app",
            "resolveSourceMapLocations": null,
            "sourceMaps": true
        }
    ],
    "compounds": [
        {
            "name": "Debug Full-Stack (Client & Server)",
            "configurations": [
                "Debug Server (React Router)",
                "Debug Client (Chrome)"
            ]
        }
    ]
}